# ── Google Gemini API ──────────────────────────────────────────
GOOGLE_API_KEY=your_google_api_key_here

# ── Model Settings ─────────────────────────────────────────────
LLM_MODEL=gemini-2.5-flash
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1024

# ── Persona Classification ─────────────────────────────────────
PERSONA_CONFIDENCE_THRESHOLD=0.6

# ── RAG / Knowledge Base ──────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
RETRIEVAL_TOP_K=5
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ── Escalation ─────────────────────────────────────────────────
ESCALATION_SENTIMENT_THRESHOLD=-0.5
ESCALATION_CONFIDENCE_THRESHOLD=0.4

# ── Logging ────────────────────────────────────────────────────
LOG_LEVEL=INFO
